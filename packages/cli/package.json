{
  "name": "cybermat",
  "version": "0.2.2",
  "description": "CyberMat Shield — local-first application security scanner (static, runtime, auth/access-control)",
  "keywords": [
    "security",
    "appsec",
    "sast",
    "scanner",
    "owasp",
    "sarif",
    "cli",
    "secrets",
    "xss",
    "injection"
  ],
  "author": "CyberMat Shield Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Martysunshine/cybermat-shield.git"
  },
  "homepage": "https://github.com/Martysunshine/cybermat-shield#readme",
  "bugs": {
    "url": "https://github.com/Martysunshine/cybermat-shield/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "bin": {
    "cybermat": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node esbuild.config.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "@cybermat/core": "workspace:*",
    "@cybermat/rules": "workspace:*",
    "@cybermat/shared": "workspace:*",
    "@types/node": "^20.0.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
