{
  "name": "@cybermat/cli",
  "version": "0.1.0",
  "bin": {
    "appsec": "./dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@cybermat/core": "workspace:*",
    "@cybermat/rules": "workspace:*",
    "@cybermat/shared": "workspace:*",
    "chalk": "^4.1.2",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  }
}
